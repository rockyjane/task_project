DB_HOST=127.0.0.1 # 我要連到我自己電腦上的某個服務，不要用 mysql，因為 mysql 是 Docker 裡的服務名稱，只有在 Docker container 彼此之間 才能用
DB_PORT=3306 # Docker 裡 MySQL 3306 映射到 我電腦的 3306，Docker 幫我做了一個「門」(我電腦:3306  →  Docker MySQL:3306)
DB_USER=root
DB_PASSWORD=root
DB_NAME=taskdb

# 我的 Mac（本機）
# ├── FastAPI（直接在本機跑）
# └── Docker
#     └── MySQL（container 裡）
# 可以把它想成：
# FastAPI = 你本機跑的 Vue dev server (localhost:8080)
# MySQL = Docker 裡的一個「後端 API server」
# | IP or HOST   | 大樓地址            |
# | PORT         | 幾樓幾號 or 門牌號碼 |
# | USER         | MySQL 帳號         |
# | PASSWORD     | MySQL 密碼         |
# | NAME         | 資料庫（database）  |
# 地址：你家（127.0.0.1）
# 門口：3306（Docker 幫我開）
# 裡面：MySQL

# 正常情況：
# 一個 service or 小專案 → 一個 DB
# 若是多 DB(只有在這些情況才會需要 ->資料量爆炸（幾億筆）、不同團隊維護、需要獨立擴展)：
# 一個 .env(更改 DB_NAME 名稱，如：DB_MAIN_NAME、DB_LOG_NAME...) => DB_MAIN_NAME=taskdb、DB_LOG_NAME=logdb
# ↓
# 一個 database.py(命名多個不同 URL，如：MAIN_DATABASE_URL、LOG_DATABASE_URL...) => MAIN_DATABASE_URL = (f"mysql+pymysql://{DB_USER}:{DB_PASSWORD}"f"@{DB_HOST}:{DB_PORT}/{os.getenv('DB_MAIN_NAME')}")
# ↓
# 多個 engine(命名多個不同的引擎，如：engine_main、engine_log...) => engine_main = create_engine(MAIN_DATABASE_URL)
# ↓
# 多個 session(命名多個不同的工廠，如：SessionMain、SessionLog...) => SessionMain = sessionmaker(bind=engine_main)
# ↓
# 多個 Base(各自的 model 要區分不同名稱的 DB，為了讓 create_all 方便建表，切記將妳要的表 bind 到正確的 DB) => class User(BaseMain): __tablename__ = "users"..., BaseMain.metadata.create_all(bind=engine_main)